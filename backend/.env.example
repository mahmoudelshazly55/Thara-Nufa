NODE_ENV=production
PORT=4000

# PostgreSQL — غيّر القيم قبل الرفع
DATABASE_URL=postgresql://thara_user:STRONG_PASSWORD_HERE@postgres:5432/thara_db

# JWT — استخدم string عشوائي طويل (32+ حرف)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_eg_openssl_rand_hex_32

# CORS — domain الموقع الحقيقي
ALLOWED_ORIGINS=https://yourdomain.com

# ─── Email (Gmail) ──────────────────────────────────────────────
# الخطوات:
#   1. فعّل 2FA على حساب Gmail
#   2. اذهب لـ myaccount.google.com/apppasswords
#   3. أنشئ App Password → انسخه هنا
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_real_email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=noreply@tharanufa.sa
EMAIL_TO=admin@tharanufa.sa
# ────────────────────────────────────────────────────────────────

# Admin seed — غيّر كلمة المرور
ADMIN_EMAIL=admin@tharanufa.sa
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_NAME=Thara Admin

# ── Email ──────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="ثرا نوفا <your_email@gmail.com>"
# For SMTP (optional, Gmail used by default):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
