# ╔══════════════════════════════════════════════════╗
# ║  .env.example — Copy to .env and fill values   ║
# ║  NEVER commit .env to Git                      ║
# ╚══════════════════════════════════════════════════╝

# Database
DB_USER=thara_user
DB_PASSWORD=change_me_strong_password_here
DB_NAME=thara_db

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change_me_64_char_random_string_here

# Admin credentials
ADMIN_EMAIL=admin@tharanufa.sa
ADMIN_PASSWORD=change_me_strong_admin_password
ADMIN_NAME=Thara Admin

# CORS — your production domain(s), comma-separated
ALLOWED_ORIGINS=https://tharanufa.sa

# ── Email (Nodemailer) ─────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
# Get one at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="ثرا نوفا <your_email@gmail.com>"
# For SMTP (optional):
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
